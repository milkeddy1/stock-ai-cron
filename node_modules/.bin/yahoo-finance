#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/Users/eddy/Desktop/stock-ai-cron/node_modules/.pnpm/yahoo-finance2@3.14.0/node_modules/yahoo-finance2/node_modules:/Users/eddy/Desktop/stock-ai-cron/node_modules/.pnpm/yahoo-finance2@3.14.0/node_modules:/Users/eddy/Desktop/stock-ai-cron/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/Users/eddy/Desktop/stock-ai-cron/node_modules/.pnpm/yahoo-finance2@3.14.0/node_modules/yahoo-finance2/node_modules:/Users/eddy/Desktop/stock-ai-cron/node_modules/.pnpm/yahoo-finance2@3.14.0/node_modules:/Users/eddy/Desktop/stock-ai-cron/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../.pnpm/yahoo-finance2@3.14.0/node_modules/yahoo-finance2/esm/bin/yahoo-finance.js" "$@"
else
  exec node  "$basedir/../.pnpm/yahoo-finance2@3.14.0/node_modules/yahoo-finance2/esm/bin/yahoo-finance.js" "$@"
fi
